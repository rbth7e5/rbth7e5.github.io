---
import Icon from "./Icon.astro";

const links = [
  { href: "#home", label: "Home" },
  { href: "#experience", label: "Experience" },
  { href: "#skills", label: "Skills" },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a
      href="#home"
      class="font-heading text-lg font-bold tracking-tight transition-colors hover:text-cyan-400"
    >
      CJ
    </a>

    <div class="hidden items-center gap-8 sm:flex">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="text-sm text-slate-400 transition-colors hover:text-white"
          >
            {label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-4">
      <a
        href="https://github.com/rbth7e5"
        target="_blank"
        rel="noopener"
        class="text-slate-400 transition-colors hover:text-white"
        aria-label="GitHub"
      >
        <Icon name="github" />
      </a>
      <a
        href="https://www.linkedin.com/in/chen-caijie/"
        target="_blank"
        rel="noopener"
        class="text-slate-400 transition-colors hover:text-white"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" />
      </a>

      <button
        id="menu-toggle"
        class="text-slate-400 transition-colors hover:text-white sm:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-open-icon" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="menu-close-icon" class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-slate-800/50 bg-slate-900/95 backdrop-blur-lg sm:hidden"
  >
    <div class="flex flex-col px-6 py-4 gap-4">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="mobile-nav-link text-sm text-slate-300 transition-colors hover:text-white"
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav");
  const toggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const openIcon = document.getElementById("menu-open-icon");
  const closeIcon = document.getElementById("menu-close-icon");

  if (toggle && mobileMenu && openIcon && closeIcon) {
    toggle.addEventListener("click", () => {
      const isOpen = !mobileMenu.classList.contains("hidden");
      mobileMenu.classList.toggle("hidden");
      openIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!isOpen));
    });

    mobileMenu.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        openIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  if (nav) {
    window.addEventListener(
      "scroll",
      () => {
        if (window.scrollY > 50) {
          nav.classList.add(
            "bg-slate-900/80",
            "backdrop-blur-lg",
            "border-b",
            "border-slate-800/50",
          );
        } else {
          nav.classList.remove(
            "bg-slate-900/80",
            "backdrop-blur-lg",
            "border-b",
            "border-slate-800/50",
          );
        }
      },
      { passive: true },
    );
  }
</script>
