---
import GlassCard from "./ui/GlassCard.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const categories = [
  {
    name: "Languages",
    skills: ["TypeScript", "C#", "SQL", "Java", "Python"],
  },
  {
    name: "Frontend",
    skills: ["React", "GraphQL (Apollo)", "SCSS", "Ant Design"],
  },
  {
    name: "Backend",
    skills: [".NET / C#", "REST APIs", "SQL Server", "GraphQL Schema Design"],
  },
  {
    name: "Practices",
    skills: ["System Design", "CI/CD", "Unit & Integration Testing", "Feature Flags", "Agile"],
  },
];
---

<GlassCard id="skills" data-ga-section="skills" class="mt-16">
  <SectionHeading class="mb-10">
    Skills
  </SectionHeading>
  <div class="space-y-8">
    {
      categories.map(({ name, skills }) => (
        <div>
          <h3 class="mb-4 text-sm font-medium uppercase tracking-wider text-slate-500">
            {name}
          </h3>
          <div class="flex flex-wrap gap-3">
            {skills.map((skill) => (
              <span class="rounded-lg border border-slate-700 bg-slate-800 px-4 py-2 text-sm font-medium text-slate-200 transition-colors hover:border-amber-500/50 hover:text-amber-400">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</GlassCard>

