---
import Icon from "./ui/Icon.astro";
---

<div id="navbar">
  <ul class="container mx-auto flex flex-row items-center justify-between px-6 py-4 max-w-5xl">
    <div class="flex flex-row items-center gap-6">
      <li class="list-none">
        <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors active-light px-3 py-1.5" href="#home">Home</a>
      </li>
      <li class="list-none">
        <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors px-3 py-1.5" href="#about">About</a>
      </li>
      <li class="list-none">
        <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors px-3 py-1.5" href="#timeline">Timeline</a>
      </li>
    </div>
    <div class="flex flex-row items-center gap-6">
      <div class="flex items-center gap-4">
        <a href="https://www.github.com/rbth7e5" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors" aria-label="GitHub">
          <Icon name="github" class="h-5 w-5" />
        </a>
        <a href="https://www.linkedin.com/in/chen-caijie/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors" aria-label="LinkedIn">
          <Icon name="linkedin" class="h-5 w-5" />
        </a>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="mailto:caijie96@gmail.com"
          class="rounded-lg border border-slate-700 bg-slate-800/50 hover:bg-white hover:text-slate-900 px-4 py-1.5 text-xs font-semibold text-slate-300 transition-colors"
        >
          Email Me
        </a>
        <button
          id="navbar-resume"
          class="rounded-lg border border-slate-700 bg-slate-800/50 hover:bg-white hover:text-slate-900 px-4 py-1.5 text-xs font-semibold text-slate-300 transition-colors cursor-pointer"
        >
          My Resume
        </button>
      </div>
    </div>
  </ul>
</div>

<style>
/* Top Navbar animations */
#navbar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 56px;
  opacity: 1;
  z-index: 999;
  overflow: hidden;
  transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  pointer-events: auto;
}

:global(.scrolled) #navbar {
  top: 64px;
  left: -64px;
  width: 0%;
  height: 0px;
  opacity: 0;
  pointer-events: none;
}

@media only screen and (max-width: 768px) {
  #navbar {
    display: none !important;
  }
}
</style>
