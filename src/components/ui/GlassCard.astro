---
interface Props {
  class?: string;
  id?: string;
  animate?: boolean;
  [key: string]: any;
}

const { class: className = "", id, animate = true, ...rest } = Astro.props;
---

<div
  id={id}
  class={`glass-card rounded-xl p-6 md:p-8 hover:border-slate-500 transition-all duration-300 shadow-lg ${className}`}
  data-animate={animate ? "" : undefined}
  {...rest}
>
  <slot />
</div>

<style>
.glass-card {
  background-color: rgba(18, 16, 14, 0.7) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
}
</style>
