---
import GlassCard from "./GlassCard.astro";

interface Props {
  company: string;
  role: string;
  period?: string;
  image: string;
  featured?: boolean;
  class?: string;
  [key: string]: any;
}

const { company, role, period, image, featured = false, class: className = "", ...rest } = Astro.props;
---

<GlassCard class={`flex flex-col ${featured ? 'md:flex-row gap-6' : 'h-full'} ${className}`} {...rest}>
  <div
    class={`bg-cover bg-center rounded-lg shadow-inner shrink-0 ${
      featured 
        ? 'w-full md:w-[380px] h-64 md:h-auto' 
        : 'w-full h-40 mb-4'
    }`}
    style={`background-image: url('${image}');`}
  />
  <div class="flex flex-col justify-center flex-1">
    <div class={`flex flex-col ${featured ? 'md:flex-row md:items-baseline gap-1 md:gap-3 mb-1' : 'mb-3'}`}>
      <h3 class="font-heading text-lg md:text-xl font-bold text-white">{company}</h3>
      <span class="text-xs font-semibold text-amber-400 uppercase tracking-wider">{role}</span>
      {period && (
        <span class={`text-xs text-slate-500 ${featured ? 'md:ml-auto' : 'mt-1'} shrink-0`}>
          {period}
        </span>
      )}
    </div>
    <div class="text-sm text-slate-300 leading-relaxed font-sans flex-1">
      <slot />
    </div>
  </div>
</GlassCard>
