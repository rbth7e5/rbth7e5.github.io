---
import Icon from "./ui/Icon.astro";
---

<div id="avatar" class="avatar-container">
  <img src="/images/avatar.jpg" alt="CJ" class="avatar" />
  <div id="navbar-list" class="nav-list">
    <a class="list-icon active-light" href="#home" style="--i: 0; --len: 7;">
      <Icon name="home" class="h-4 w-4" />
      <span>Home</span>
    </a>
    <a class="list-icon" href="#about" style="--i: 1; --len: 7;">
      <Icon name="about" class="h-4 w-4" />
      <span>About</span>
    </a>
    <a class="list-icon" href="#timeline" style="--i: 2; --len: 7;">
      <Icon name="timeline" class="h-4 w-4" />
      <span>Timeline</span>
    </a>
    <a class="list-icon" href="https://www.github.com/rbth7e5" target="_blank" rel="noopener" style="--i: 3; --len: 7;">
      <Icon name="github" class="h-4 w-4" />
      <span>GitHub</span>
    </a>
    <a class="list-icon" href="https://www.linkedin.com/in/chen-caijie/" target="_blank" rel="noopener" style="--i: 4; --len: 7;">
      <Icon name="linkedin" class="h-4 w-4" />
      <span>LinkedIn</span>
    </a>
    <a class="list-icon" href="mailto:caijie96@gmail.com" style="--i: 5; --len: 7;">
      <Icon name="email" class="h-4 w-4" />
      <span>Email</span>
    </a>
    <a class="list-icon" id="resume-icon" style="--i: 6; --len: 7; cursor: pointer;">
      <Icon name="resume" class="h-4 w-4" />
      <span>Resume</span>
    </a>
  </div>
  <div class="speech-bubble">
    <span id="avatar-text">Hello I'm Caijie</span>
  </div>
  <div id="intro-content" class="intro-content text-slate-300">
    <p id="intro-text" class="text-sm md:text-base leading-relaxed">
      I love to build things and solve complex problems!
      <br />
      Currently, I'm a Senior Software Engineer at <strong class="text-white font-semibold">The Trade Desk</strong> in the Singapore Office.
      <br />
      I have a cat, I love singing, and I love skiing!
      <br />
      Scroll down to find out more! You can also find the source code for
      this website
      <a href="https://github.com/rbth7e5/rbth7e5.github.io" class="text-amber-400 hover:text-amber-300 transition-colors">here</a>.
    </p>
  </div>
</div>

<script>
  // Drag Element Logic
  const dragElement = (elmnt: HTMLElement) => {
    let pos1 = 0,
      pos2 = 0,
      pos3 = 0,
      pos4 = 0;

    elmnt.onmousedown = dragMouseDown;
    elmnt.addEventListener("touchstart", dragTouchStart, { passive: false });

    function dragMouseDown(e: MouseEvent) {
      // Don't drag if clicking links
      if ((e.target as HTMLElement).closest("a") || (e.target as HTMLElement).closest("button")) return;
      e = e || window.event;
      e.preventDefault();
      
      elmnt.classList.add("dragging");
      
      // get the mouse cursor position at startup:
      pos3 = e.clientX;
      pos4 = e.clientY;
      document.onmouseup = closeDragElement;
      // call a function whenever the cursor moves:
      document.onmousemove = elementDrag;
    }

    function elementDrag(e: MouseEvent) {
      e = e || window.event;
      e.preventDefault();
      // calculate the new cursor position:
      pos1 = pos3 - e.clientX;
      pos2 = pos4 - e.clientY;
      pos3 = e.clientX;
      pos4 = e.clientY;
      // set the element's new position:
      elmnt.style.top = elmnt.offsetTop - pos2 + "px";
      elmnt.style.left = elmnt.offsetLeft - pos1 + "px";
    }

    function closeDragElement() {
      elmnt.classList.remove("dragging");
      // stop moving when mouse button is released:
      document.onmouseup = null;
      document.onmousemove = null;
    }

    function dragTouchStart(e: TouchEvent) {
      if ((e.target as HTMLElement).closest("a") || (e.target as HTMLElement).closest("button")) return;
      e.preventDefault();
      
      elmnt.classList.add("dragging");
      
      const touch = e.touches[0];
      pos3 = touch.clientX;
      pos4 = touch.clientY;
      document.addEventListener("touchend", closeDragTouch, { passive: false });
      document.addEventListener("touchmove", elementTouchDrag, { passive: false });
    }

    function elementTouchDrag(e: TouchEvent) {
      e.preventDefault();
      const touch = e.touches[0];
      pos1 = pos3 - touch.clientX;
      pos2 = pos4 - touch.clientY;
      pos3 = touch.clientX;
      pos4 = touch.clientY;
      elmnt.style.top = elmnt.offsetTop - pos2 + "px";
      elmnt.style.left = elmnt.offsetLeft - pos1 + "px";
    }

    function closeDragTouch() {
      elmnt.classList.remove("dragging");
      document.removeEventListener("touchend", closeDragTouch);
      document.removeEventListener("touchmove", elementTouchDrag);
    }
  };

  // Mobile list-menu spacing calculations
  const updateMobileSpacing = () => {
    const avatar = document.getElementById("avatar");
    if (avatar) {
      const spacing = (window.innerWidth - window.innerWidth / 5 - 48) / 7;
      avatar.style.setProperty("--mobile-spacing", `${spacing}px`);
    }
  };

  const downloadResume = () => {
    window.open(
      "https://docs.google.com/document/d/1NPI-piwKe-UpZ0HXgYMwgq9PFD0h3gsX1yV5ZfGd3ko/edit?usp=sharing",
      "_blank"
    )?.focus();
  };

  // Initialize
  const avatarEl = document.getElementById("avatar");
  if (avatarEl) {
    dragElement(avatarEl);
  }

  const resumeIcon = document.getElementById("resume-icon");
  if (resumeIcon) {
    resumeIcon.onclick = downloadResume;
  }

  // Spacing listeners
  updateMobileSpacing();
  window.addEventListener("resize", () => {
    updateMobileSpacing();
  });
</script>

<style>
/* Interactive Avatar and Radial Menu */
.avatar-container {
  position: absolute;
  top: calc(60vh - 32px);
  left: calc(50% - 32px);
  z-index: 9999;
  width: 64px;
  height: 64px;
  display: flex;
  justify-content: center;
  align-items: center;
  visibility: hidden;
  transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.avatar-container.dragging {
  transition: none !important;
}

.avatar {
  border-radius: 50%;
  width: 0;
  height: 0;
  box-shadow: 0 0 8px 1px black;
  animation: avatar-popup 0.5s ease 1;
  animation-fill-mode: forwards;
  animation-delay: 1s;
  cursor: move;
}

@keyframes avatar-popup {
  to {
    width: 64px;
    height: 64px;
  }
}

@media only screen and (min-width: 768px) {
  .avatar-container {
    top: calc(50vh - 64px);
    left: calc(50% - 64px);
    width: 128px;
    height: 128px;
  }

  @keyframes avatar-popup {
    to {
      width: 128px;
      height: 128px;
    }
  }
}

/* Scrolled state transitions */
:global(.scrolled) .avatar-container {
  top: 64px !important;
  left: 64px !important;
  opacity: 0.75;
}

@media only screen and (max-width: 768px) {
  :global(.scrolled) .avatar-container {
    top: calc(10vw) !important;
    left: calc(10vw) !important;
    opacity: 0.75;
  }
}

/* Nav Menu Icons */
.nav-list {
  display: flex;
  flex-direction: column;
  position: absolute;
  z-index: 998;
}

.list-icon {
  position: absolute;
  width: 128px;
  height: 32px;
  top: -16px;
  left: -32px;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  border-radius: 8px;
  background-color: #6c757d;
  border: 1px solid white;
  z-index: 998;
  opacity: 1;
  color: white;
  text-decoration: none;
  transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.list-icon i,
.list-icon :global(svg) {
  color: inherit;
  padding: 4px;
}

.list-icon span {
  opacity: 1;
  margin-left: 2px;
  width: 94px;
  transition: opacity 0.4s ease, width 0.4s ease;
}

.list-icon:hover {
  background-color: white;
  color: #6c757d;
}

/* Radial layouts - desktop */
@media only screen and (min-width: 768px) {
  .list-icon {
    width: 26px;
    height: 26px;
    top: -13px;
    left: -13px;
    opacity: 0;
    border-radius: 50%;
    z-index: -1;
  }

  .list-icon span {
    display: none;
    opacity: 0;
    width: 0;
  }

  /* Expand radially when scrolled on desktop */
  :global(.scrolled) .list-icon {
    opacity: 1;
    z-index: 998;
  }
  :global(.scrolled) .list-icon:nth-child(1) { transform: translate(-4px, -88px); }
  :global(.scrolled) .list-icon:nth-child(2) { transform: translate(-41px, -78px); }
  :global(.scrolled) .list-icon:nth-child(3) { transform: translate(-70px, -54px); }
  :global(.scrolled) .list-icon:nth-child(4) { transform: translate(-86px, -19px); }
  :global(.scrolled) .list-icon:nth-child(5) { transform: translate(-86px, 19px); }
  :global(.scrolled) .list-icon:nth-child(6) { transform: translate(-70px, 54px); }
  :global(.scrolled) .list-icon:nth-child(7) { transform: translate(-41px, 78px); }
}

/* Stacking layouts - mobile */
@media only screen and (max-width: 768px) {
  /* Restored mobile state (vertical stack above avatar) */
  .list-icon {
    transform: translate(0, calc((var(--i) - var(--len)) * 38px - 32px));
  }

  /* Scrolled mobile state (horizontal row below avatar using flexbox) */
  :global(.scrolled) .nav-list {
    display: flex !important;
    flex-direction: row !important;
    position: absolute !important;
    top: 32px !important;
    left: -24px !important;
    width: auto !important;
    height: auto !important;
    gap: 4px !important;
    z-index: 998 !important;
  }

  :global(.scrolled) .list-icon {
    position: static !important;
    transform: none !important;
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    overflow: hidden !important;
    justify-content: flex-start !important;
    padding-left: 8px !important;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-radius 0.3s ease, background-color 0.3s ease !important;
  }

  :global(.scrolled) .list-icon span {
    opacity: 0;
    width: 0;
    display: inline-block !important;
    white-space: nowrap;
    transition: opacity 0.2s ease, width 0.2s ease;
  }

  /* Expand on hover or active state when scrolled on mobile */
  :global(.scrolled) .list-icon:hover,
  :global(.scrolled) .list-icon:global(.active-light) {
    width: 96px !important;
    border-radius: 8px !important;
  }

  :global(.scrolled) .list-icon:hover span,
  :global(.scrolled) .list-icon:global(.active-light) span {
    opacity: 1 !important;
    width: 52px !important;
    margin-left: 6px !important;
  }

  /* Speech bubble mobile positioning to prevent screen overflow */
  .speech-bubble {
    left: 75px !important;
    top: 12px !important;
    font-size: 14px !important;
    padding: 4px 8px !important;
  }

  .speech-bubble:after {
    border-width: 12px 12px 0 0 !important;
    margin-left: -12px !important;
    margin-top: -6px !important;
  }
}

/* Speech Bubble and Intro Text */
.speech-bubble {
  position: absolute;
  left: 100px;
  top: 0;
  background: white;
  color: black;
  border-radius: 8px;
  padding: 6px;
  font-size: 20px;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  animation: speech-bubble-anim 0.5s ease 1;
  animation-fill-mode: forwards;
  animation-delay: 1000ms;
}

.speech-bubble:after {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 0;
  height: 0;
  border: 20px solid transparent;
  border-right-color: white;
  border-left: 0;
  border-bottom: 0;
  margin-top: -10px;
  margin-left: -20px;
}

@media only screen and (min-width: 768px) {
  .speech-bubble {
    left: 160px;
    top: -16px;
    padding: 8px;
  }
}

@keyframes speech-bubble-anim {
  to {
    opacity: 1;
  }
}

.intro-content {
  pointer-events: none;
  position: absolute;
  top: 80px;
  left: calc(-40vw + 32px);
  border-radius: 8px;
  z-index: 998;
  width: 80vw;
  color: white;
  opacity: 0;
  animation: speech-bubble-anim 0.5s ease 1;
  animation-fill-mode: forwards;
  animation-delay: 1200ms;
  transition: opacity 0.4s ease;
  text-align: center;
}

.intro-content a {
  pointer-events: auto;
  text-decoration: underline;
}

@media only screen and (min-width: 768px) {
  .intro-content {
    top: 150px;
    left: calc(-25vw + 64px);
    width: 50vw;
  }
}

/* Hide speech bubble and intro when scrolled */
:global(.scrolled) .speech-bubble,
:global(.scrolled) .intro-content {
  opacity: 0 !important;
  pointer-events: none;
}

/* Active status styling overrides for lists */
@media only screen and (min-width: 768px) {
  .nav-list :global(.active-light) {
    border-radius: 50% !important;
  }
  :global(.scrolled) .nav-list :global(.active-light) {
    border-radius: 50% !important;
  }
}
</style>
