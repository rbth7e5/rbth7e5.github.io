---
import Icon from "./Icon.astro";
---

<footer class="border-t border-slate-800 py-12">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="mb-6 flex justify-center gap-6 text-slate-400">
      <a
        href="https://github.com/rbth7e5"
        target="_blank"
        rel="noopener"
        data-ga-event="external_link_click"
        data-ga-label="github"
        class="transition-colors hover:text-cyan-400"
        aria-label="GitHub"
      >
        <Icon name="github" />
      </a>
      <a
        href="https://www.linkedin.com/in/chen-caijie/"
        target="_blank"
        rel="noopener"
        data-ga-event="external_link_click"
        data-ga-label="linkedin"
        class="transition-colors hover:text-cyan-400"
        aria-label="LinkedIn"
      >
        <Icon name="linkedin" />
      </a>
      <a
        href="mailto:caijie96@gmail.com"
        data-ga-event="contact_click"
        data-ga-label="footer"
        class="transition-colors hover:text-cyan-400"
        aria-label="Email"
      >
        <Icon name="email" />
      </a>
      <a
        href="https://docs.google.com/document/d/1NPI-piwKe-UpZ0HXgYMwgq9PFD0h3gsX1yV5ZfGd3ko/export?format=pdf"
        target="_blank"
        rel="noopener"
        data-ga-event="resume_download"
        data-ga-label="footer"
        class="transition-colors hover:text-cyan-400"
        aria-label="Resume"
      >
        <Icon name="download" />
      </a>
    </div>
    <p class="text-sm text-slate-500">&copy; 2026 Chen Caijie</p>
  </div>
</footer>
