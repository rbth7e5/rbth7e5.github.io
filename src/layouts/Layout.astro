---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Chen Caijie — Software Engineer",
  description = "Software Engineer at The Trade Desk. Full-stack engineer building TTD's next-generation media buying platform with React, TypeScript, C#, and GraphQL.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-60YF2FY9NW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-60YF2FY9NW");
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://rbth7e5.github.io" />
    <meta property="og:image" content="https://rbth7e5.github.io/images/avatar.jpg" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0f172a" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-slate-900 text-slate-100 antialiased">
    <slot />
    <script>
      document.addEventListener("click", (e) => {
        const el = e.target.closest("[data-ga-event]");
        if (!el || typeof gtag !== "function") return;
        const eventName = el.getAttribute("data-ga-event");
        const label = el.getAttribute("data-ga-label");
        if (eventName) {
          gtag("event", eventName, label ? { event_label: label } : {});
        }
      });

      const sectionsSeen = new Set();
      const animationObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
      );
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const section = entry.target.getAttribute("data-ga-section");
            if (section && !sectionsSeen.has(section) && typeof gtag === "function") {
              sectionsSeen.add(section);
              gtag("event", "section_view", { event_label: section });
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
      );

      document.querySelectorAll("[data-animate]").forEach((el) => animationObserver.observe(el));
      document.querySelectorAll("[data-ga-section]").forEach((el) => sectionObserver.observe(el));
    </script>
  </body>
</html>
