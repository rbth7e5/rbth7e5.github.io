---
import Layout from "../layouts/Layout.astro";
import InteractiveAvatar from "../components/InteractiveAvatar.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import Timeline from "../components/Timeline.astro";
import Skills from "../components/Skills.astro";
import Icon from "../components/ui/Icon.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import GlassCard from "../components/ui/GlassCard.astro";
import WorkCard from "../components/ui/WorkCard.astro";
import Carousel from "../components/ui/Carousel.astro";
---

<Layout>
  <!-- Spinner loader -->
  <div id="loader" class="loading"></div>

  <!-- SVG Spotlight Mask -->
  <svg viewBox="0 0 100vw 100vh" class="mask">
    <defs>
      <mask id="mask" x="0" y="0" width="100%" height="100%">
        <rect x="0" y="0" width="100%" height="100%" fill="#fff" />
        <circle />
      </mask>
    </defs>
    <rect
      x="0"
      y="0"
      width="100%"
      height="100%"
      mask="url(#mask)"
      fill-opacity="0.7"
    />
  </svg>

  <!-- Background Blur Overlay -->
  <div class="background-overlay"></div>

  <!-- Draggable avatar component -->
  <InteractiveAvatar />

  <!-- Scrollable content container -->
  <div id="scroll-container" class="scroll-container">
    <!-- Navbar -->
    <div id="navbar">
      <ul class="container mx-auto flex flex-row items-center justify-between px-6 py-4 max-w-5xl">
        <div class="flex flex-row items-center gap-6">
          <li class="list-none">
            <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors active-light px-3 py-1.5" href="#home">Home</a>
          </li>
          <li class="list-none">
            <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors px-3 py-1.5" href="#about">About</a>
          </li>
          <li class="list-none">
            <a class="nav-link text-white hover:text-amber-400 font-medium tracking-wide transition-colors px-3 py-1.5" href="#timeline">Timeline</a>
          </li>
        </div>
        <div class="flex flex-row items-center gap-6">
          <div class="flex items-center gap-4">
            <a href="https://www.github.com/rbth7e5" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors" aria-label="GitHub">
              <Icon name="github" class="h-5 w-5" />
            </a>
            <a href="https://www.linkedin.com/in/chen-caijie/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors" aria-label="LinkedIn">
              <Icon name="linkedin" class="h-5 w-5" />
            </a>
          </div>
          <div class="flex items-center gap-3">
            <a
              href="mailto:caijie96@gmail.com"
              class="rounded-lg border border-slate-700 bg-slate-800/50 hover:bg-white hover:text-slate-900 px-4 py-1.5 text-xs font-semibold text-slate-300 transition-colors"
            >
              Email Me
            </a>
            <button
              id="navbar-resume"
              class="rounded-lg border border-slate-700 bg-slate-800/50 hover:bg-white hover:text-slate-900 px-4 py-1.5 text-xs font-semibold text-slate-300 transition-colors cursor-pointer"
            >
              My Resume
            </button>
          </div>
        </div>
      </ul>
    </div>

    <!-- Sections -->
    <section id="home" class="home">
      <div class="intro"></div>
    </section>

    <section id="about" class="about py-16 md:py-24 border-t border-slate-900/60">
      <div class="container mx-auto px-6 max-w-5xl">
        <SectionHeading>Work Experience</SectionHeading>

        <Carousel id="experience-carousel">
          <!-- TTD - featured card -->
          <WorkCard
            company="The Trade Desk"
            role="Senior Software Engineer"
            period="Aug 2022 – Present"
            image="/images/ttd.jpeg"
            featured
            class="snap-start shrink-0 w-full min-h-[420px] md:h-[380px]"
            animate={false}
          >
            <p class="text-sm text-slate-300 leading-relaxed font-sans mb-3">
              I've been at The Trade Desk for over 4 years now, working on the Kokai platform which is TTD's next-generation DSP UI. My work covers the full stack, from React and TypeScript on the frontend to C# and .NET on the backend.
            </p>
            <ul class="space-y-3 mt-4 border-t border-slate-800/60 pt-4">
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <span class="text-amber-500 mt-1 shrink-0">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span>
                  Built the <strong class="text-white font-medium">Creative Library</strong> from the ground up, covering everything from list views and search to bulk operations and assignment workflows.
                </span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <span class="text-amber-500 mt-1 shrink-0">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span>
                  Built the <strong class="text-white font-medium">Creative Troubleshooting System</strong>, a card-based UI that surfaced bid blocking issues with creatives that could impact ad group spend.
                </span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <span class="text-amber-500 mt-1 shrink-0">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span>
                  Led the <strong class="text-white font-medium">Campaign Settings Snapshot</strong> feature, a modular overview of campaign configuration that sees thousands of clicks every day.
                </span>
              </li>
            </ul>
          </WorkCard>

          <!-- Shopee -->
          <WorkCard
            company="Shopee"
            role="Front-end Software Engineer"
            image="/images/shopee.jpeg"
            featured
            class="snap-start shrink-0 w-full min-h-[420px] md:h-[380px]"
            animate={false}
          >
            <p class="text-sm text-slate-300 leading-relaxed font-sans flex-1">
              My team worked on internal tools that allowed business
              operators to configure campaign sites easily without code. I
              also contributed to internal projects that improved
              engineering productivity.
            </p>
          </WorkCard>

          <!-- Trabble -->
          <WorkCard
            company="Trabble"
            role="Software Engineer Intern"
            image="/images/trabble.png"
            featured
            class="snap-start shrink-0 w-full min-h-[420px] md:h-[380px]"
            animate={false}
          >
            <p class="text-sm text-slate-300 leading-relaxed font-sans flex-1">
              Built a facility/meeting booking web application using Blazor.
              I joined Trabble after being recalled from New York due to
              COVID-19.
            </p>
          </WorkCard>

          <!-- Coord -->
          <WorkCard
            company="Coord"
            role="Software Engineer Intern"
            image="/images/coord.jpeg"
            featured
            class="snap-start shrink-0 w-full min-h-[420px] md:h-[380px]"
            animate={false}
          >
            <p class="text-sm text-slate-300 leading-relaxed font-sans flex-1">
              A year long internship I took as part of the NUS Overseas
              College program. It was cut short due to COVID-19. Pictured
              here is Sara, my colleague!
            </p>
          </WorkCard>
        </Carousel>

        <SectionHeading class="mt-20">Projects</SectionHeading>
        <ProjectCarousel />

        <Skills />
      </div>
    </section>

    <section id="timeline" class="timeline-section py-16 md:py-24 border-t border-slate-900/60">
      <div class="container mx-auto px-6 max-w-5xl">
        <SectionHeading>Timeline</SectionHeading>
        <GlassCard>
          <Timeline />
        </GlassCard>
      </div>
    </section>
</Layout>

<script>
  const scrollContainer = document.getElementById("scroll-container") as HTMLElement;
  const navbar = document.getElementById("navbar") as HTMLElement;

  if (scrollContainer) {
    // Scroll scrolled-state class toggling
    scrollContainer.addEventListener("scroll", () => {
      if (scrollContainer.scrollTop > 50) {
        document.body.classList.add("scrolled");
      } else {
        document.body.classList.remove("scrolled");
      }
    });

    // Nav Highlighter logic
    const sections = document.querySelectorAll("section[id]");
    const navHighlighter = () => {
      let scrollY = scrollContainer.scrollTop;
      sections.forEach((current) => {
        const sectionHeight = (current as HTMLElement).offsetHeight;
        const sectionTop = (current as HTMLElement).offsetTop - 120; // Trigger slightly early
        const sectionId = current.getAttribute("id");
        const element = document.querySelector(`#navbar a[href*="${sectionId}"]`);
        const listElement = document.querySelector(`.nav-list a[href*="${sectionId}"]`);
        const avatarText = document.getElementById("avatar-text");

        if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
          if (avatarText) {
            switch (sectionId) {
              case "home":
                avatarText.innerText = "Hello I'm Caijie";
                break;
              case "about":
                avatarText.innerText = "All About Me";
                break;
              case "timeline":
                avatarText.innerText = "My Timeline";
                break;
            }
          }
          element?.classList.add("active-light");
          listElement?.classList.add("active-light");
        } else {
          element?.classList.remove("active-light");
          listElement?.classList.remove("active-light");
        }
      });
    };
    scrollContainer.addEventListener("scroll", navHighlighter);
  }

  // Load handler (fades out spinner loader)
  window.addEventListener("load", function () {
    setTimeout(() => {
      const loader = document.getElementById("loader");
      if (loader) loader.remove();
      document.body.classList.add("background-cover");
      const scrollCont = document.getElementById("scroll-container");
      const avatar = document.getElementById("avatar");
      if (scrollCont) scrollCont.style.visibility = "visible";
      if (avatar) avatar.style.visibility = "visible";
    }, 1000);
  });

  // Resume button click handler
  const resumeBtn = document.getElementById("navbar-resume");
  if (resumeBtn) {
    resumeBtn.addEventListener("click", () => {
      window.open(
        "https://docs.google.com/document/d/1NPI-piwKe-UpZ0HXgYMwgq9PFD0h3gsX1yV5ZfGd3ko/edit?usp=sharing",
        "_blank"
      )?.focus();
    });
  }
</script>
